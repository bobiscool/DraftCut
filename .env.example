# DraftCut skill · 本地密钥（复制为 .env 后填写，勿提交 git）
#
#   cp .env.example .env
#
# 脚本启动时会自动加载 skill 目录下的 .env（不覆盖 shell 里已 export 的变量）。

# 多模态读图 API Key — 与 draftcut.config.json 里 multimodal.apiKeyEnv 一致（默认 MONTAGE_API_KEY）
MONTAGE_API_KEY=

# 若 config 里 apiKeyEnv 改成别的名字，在此添加，例如千问：
# QWEN_API_KEY=

# 可选：whisper 转写用的 python（例如装了 mlx-whisper 的 venv）
# DRAFTCUT_PYTHON=

# 可选：whisper.cpp 的 ggml 模型路径
# WHISPER_CPP_MODEL=
