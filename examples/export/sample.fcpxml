<!DOCTYPE fcpxml>
<fcpxml version="1.9">
  <resources>
    <format id="r1" name="FFVideoFormat1080p30" frameDuration="1/30s" width="1920" height="1080"/>
    <asset id="r2" name="hotpot.mp4" src="file:///Users/mac/Code/montage/media/hotpot.mp4" duration="108000/30s" hasVideo="1" hasAudio="1" format="r1"/>
    <asset id="r3" name="street.mp4" src="file:///Users/mac/Code/montage/media/street.mp4" duration="108000/30s" hasVideo="1" hasAudio="1" format="r1"/>
    <asset id="r4" name="wok.mp4" src="file:///Users/mac/Code/montage/media/wok.mp4" duration="108000/30s" hasVideo="1" hasAudio="1" format="r1"/>
    <asset id="r5" name="skewer.mp4" src="file:///Users/mac/Code/montage/media/skewer.mp4" duration="108000/30s" hasVideo="1" hasAudio="1" format="r1"/>
